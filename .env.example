# Firebase Configuration (Required)
# Get these values from your Firebase Console > Project Settings > General > Your apps > Firebase SDK snippet
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef123456
REACT_APP_FIREBASE_MEASUREMENT_ID=G-ABCDEF1234

# Alternative Environment Variable Names (also supported)
# FIREBASE_API_KEY=your_firebase_api_key_here
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# FIREBASE_MESSAGING_SENDER_ID=123456789
# FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Google OAuth Configuration (Legacy)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000

# Application Configuration
REACT_APP_ENV=development
SKIP_PREFLIGHT_CHECK=true
GENERATE_SOURCEMAP=false

# Copy this file to .env and add your actual credentials
# 
# To get Firebase credentials:
# 1. Go to Firebase Console (https://console.firebase.google.com)
# 2. Select your project (or create one)
# 3. Go to Project Settings (gear icon) > General tab
# 4. Scroll down to "Your apps" section
# 5. Click on the web app or "Add app" if none exists
# 6. Copy the config values from the "Firebase SDK snippet"
#
# Important: Add your domain/origin to Firebase Authentication:
# - Go to Authentication > Settings > Authorized domains
# - Add 'localhost' for development
# - Add your Electron app's custom protocol for production